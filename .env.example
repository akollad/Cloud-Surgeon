# ─── Cloud-Surgeon — Environment Variables ────────────────────────────────────
#
# Copy this file to .env and fill in the values for local development.
# In production (Replit deployment), set these via the Secrets panel.
#
# ─── Database ─────────────────────────────────────────────────────────────────

# CockroachDB Serverless connection string (includes credentials + cluster host)
# Format: postgresql://user:password@host:26257/defaultdb?sslmode=verify-full
COCKROACHDB_URL=postgresql://user:password@cluster.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full

# ─── API Security ─────────────────────────────────────────────────────────────

# Shared secret for the Cloud-Surgeon REST API (all routes require X-API-Key header)
CLOUD_SURGEON_API_KEY=change-me-in-production

# Session signing secret (Express cookie-parser)
SESSION_SECRET=change-me-in-production

# ─── AI Provider ──────────────────────────────────────────────────────────────
#
# Controls which LLM and embedding provider the agent uses:
#
#   anthropic  — Anthropic Claude (LLM) + OpenAI text-embedding-3-small (embeddings)
#                Use in development via Replit AI Integrations (no manual API key needed).
#
#   bedrock    — Amazon Bedrock Claude Haiku (LLM) + Titan Text Embeddings V2 (embeddings)
#                Default for production. Requires AWS credentials below.
#
AI_PROVIDER=anthropic

# Replit AI Integrations — auto-provisioned, do NOT set manually.
# Run: setupReplitAIIntegrations({ providerSlug: "anthropic" }) in the Replit sandbox.
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=<auto>
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=<auto>

# ── AWS credentials (optional — enables real ECS/RDS/Lambda tool calls) ──────
# Without these, aws_repair_service returns { simulated: true } with an explicit
# reason logged. Startup log shows: [MCP] AWS tools: LIVE | region: us-east-1
# Required IAM permissions: ecs:DescribeServices, ecs:UpdateService,
#   rds:DescribeDBInstances, rds:ModifyDBInstance, cloudwatch:GetMetricStatistics,
#   lambda:GetFunctionConcurrency, lambda:PutFunctionConcurrency
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# ECS cluster name to use when serviceName doesn't include cluster/service format
ECS_DEFAULT_CLUSTER=prod-cluster

# Voyage AI embeddings — used when AI_PROVIDER=anthropic (optional upgrade).
# Without this key, a pseudo-embedding fallback is used (explicitly logged).
# Free tier: 200M tokens. Get key at: https://dash.voyageai.com
# Model: voyage-3-lite → 1024 dims (matches VECTOR(1024) schema exactly)
VOYAGE_API_KEY=

# Replit AI Integrations (OpenAI) — provisioned but NOT used for embeddings
# (the Replit proxy does not expose the /embeddings endpoint).
# AI_INTEGRATIONS_OPENAI_BASE_URL=<auto>
# AI_INTEGRATIONS_OPENAI_API_KEY=<auto>

# ─── AWS Credentials (required when AI_PROVIDER=bedrock or for real AWS tool calls) ─

# AWS IAM credentials with the following permissions:
#   bedrock:InvokeModel (for Claude Haiku + Titan Embeddings)
#   ecs:DescribeServices, ecs:UpdateService
#   rds:DescribeDBInstances
#   lambda:GetFunctionConcurrency, lambda:PutFunctionConcurrencyLimit
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ─── CockroachDB Cloud API ────────────────────────────────────────────────────

# CockroachDB Cloud API key — used by the execute_ccloud_command MCP tool
# to fetch real cluster health data. Generate at: https://cockroachlabs.cloud/access
COCKROACH_CLOUD_API_KEY=
COCKROACH_CLOUD_CLUSTER_ID=

# ─── Dashboard ────────────────────────────────────────────────────────────────

# Password to access the Streamlit dashboard (leave empty to disable auth in dev)
DASHBOARD_PASSWORD=

# Allowed CORS origin for the API server (use * in dev, set exact origin in prod)
DASHBOARD_ORIGIN=*

# ─── Optional tuning ──────────────────────────────────────────────────────────

# Max agent turns per incident (default: 3)
# MAX_AGENT_TURNS=3

# Delay before simulated crash in crash-test mode (ms, default: 0 = disabled)
# CLOUD_SURGEON_CRASH_TEST_DELAY_MS=0

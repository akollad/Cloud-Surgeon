# =============================================================================
# Cloud-Surgeon — Environment Variables
# Copy this file to .env and fill in the values for local development.
# In production (Replit Deployments), set these via the Secrets panel.
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────

# CockroachDB Serverless connection string (required).
# Format: postgresql://<user>:<password>@<host>:26257/<database>?sslmode=verify-full
COCKROACHDB_URL=postgresql://root@localhost:26257/cloud_surgeon?sslmode=disable

# ── API Authentication ────────────────────────────────────────────────────────

# Shared API key between the React dashboard and the Node.js API server.
# Generate a strong random value for production: `openssl rand -hex 32`
CLOUD_SURGEON_API_KEY=change-me-before-deploying

# Session secret for cookie signing (used by express-session if added).
# Generate with: `openssl rand -base64 32`
SESSION_SECRET=change-me-before-deploying

# ── AI Provider ──────────────────────────────────────────────────────────────

# Which LLM provider to use: "anthropic" (dev) or "bedrock" (prod).
# Default: anthropic
AI_PROVIDER=anthropic

# Anthropic API key — required when AI_PROVIDER=anthropic.
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key — enables semantic RAG embeddings.
# Without this, the agent falls back to a deterministic hash embedding.
# Obtain from https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# ── AWS Integration ───────────────────────────────────────────────────────────

# AWS credentials for live tool calls (ECS, RDS, Lambda, CloudWatch).
# When unset, the agent uses SIMULATED mode (safe for demo).
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── CockroachDB Cloud API ─────────────────────────────────────────────────────

# Required to call CockroachDB Cloud API (cluster management, metrics).
# Generate in https://cockroachlabs.cloud/access-management
COCKROACH_CLOUD_API_KEY=...

# The cluster UUID shown in the CockroachDB Cloud console.
COCKROACH_CLOUD_CLUSTER_ID=...

# ── Dashboard ────────────────────────────────────────────────────────────────

# Password to protect the React dashboard (inlined at Vite build time via VITE_DASHBOARD_PASSWORD).
# If unset, the dashboard is accessible without a password (dev only).
VITE_DASHBOARD_PASSWORD=change-me-before-deploying

# Base URL of the API server as seen from the dashboard build.
# In Replit dev this is set automatically. In production, point to the CloudFront /api path.
# Example: https://d3ddnpg3hz3st4.cloudfront.net/api
VITE_API_BASE_URL=http://localhost:8080/api

# API key used by the dashboard to authenticate against the API server.
VITE_API_KEY=change-me-before-deploying

# ── CDC (CockroachDB Changefeed) ──────────────────────────────────────────────

# Full public HTTPS URL for the CockroachDB changefeed webhook sink.
# Required in ECS / production — without it, the API server falls back to 2-second polling.
# In Replit dev this is derived automatically from REPLIT_DEV_DOMAIN; leave blank locally.
# Example: https://d3ddnpg3hz3st4.cloudfront.net/api/internal/cdc
CDC_WEBHOOK_URL=

# ── Amazon Bedrock ───────────────────────────────────────────────────────────

# Bedrock API key (new Bedrock API-key feature — simpler than SigV4).
# Create one in the AWS Console under Bedrock → API keys → Create API key.
# Looks like: bdak-...
# When set, takes priority over AWS_ACCESS_KEY_ID for Bedrock calls.
BEDROCK_API_KEY=bdak-...

# AWS region where your Bedrock service is activated.
# Default: eu-west-1 (change if your Bedrock is in a different region).
BEDROCK_REGION=eu-west-1

# ── Calibration ──────────────────────────────────────────────────────────────

# Deviation threshold that triggers a strategy correction factor (default 0.15 = 15%).
# A lower value makes calibration more aggressive; higher = more tolerant.
CALIBRATION_THRESHOLD=0.15

{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development pnpm run build && bash -c 'while true; do node --enable-source-maps ./dist/index.mjs; EXIT=$?; [ $EXIT -eq 0 ] && break; echo \"[auto-restart] Server exited (code $EXIT) — restarting in 2s...\"; sleep 2; done'",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/lib/anomaly.test.ts src/lib/prompt-guard.test.ts src/lib/cloud-surgeon.routing.test.ts",
    "test:e2e": "TEST_API_URL=http://localhost:8080/api TEST_API_PASSWORD=cloudsurgeon-demo tsx --test src/lib/agent-loop.e2e.test.ts",
    "test:cdc-recovery": "tsx --test src/lib/cdc-recovery.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1085.0",
    "@aws-sdk/client-cloudwatch": "^3.1085.0",
    "@aws-sdk/client-ecs": "^3.1085.0",
    "@aws-sdk/client-lambda": "^3.1085.0",
    "@aws-sdk/client-rds": "^3.1085.0",
    "@aws-sdk/client-sns": "^3.1087.0",
    "@aws-sdk/client-sqs": "^3.1087.0",
    "@aws-sdk/client-ssm": "^3.1088.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-anthropic-ai": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1085.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/node": "catalog:",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}

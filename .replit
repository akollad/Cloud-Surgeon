modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dashboard"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "Dashboard"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23183 BASE_PATH=/dashboard/ pnpm --filter @workspace/dashboard run dev"
waitForPort = 23183

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AI_PROVIDER = "mistral"
BEDROCK_REGION = "eu-west-1"
AWS_REGION = "us-east-1"
ECS_DEFAULT_CLUSTER = "cloud-surgeon"
ECS_DEFAULT_SERVICE = "api"
LAMBDA_DEFAULT_FUNCTION = "order-processor"

modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AI_PROVIDER = "mistral"
BEDROCK_REGION = "eu-west-1"
AWS_REGION = "us-east-1"
ECS_DEFAULT_CLUSTER = "cloud-surgeon"
ECS_DEFAULT_SERVICE = "api"
LAMBDA_DEFAULT_FUNCTION = "order-processor"
